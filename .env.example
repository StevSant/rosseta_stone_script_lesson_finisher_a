# ==========================================
# ROSETTA STONE CONFIGURATION
# ==========================================

# --- Credenciales de acceso ---
ROSETTA_EMAIL=tu_email@ejemplo.com
ROSETTA_PASSWORD=tu_contraseña

# --- URLs ---
ROSETTA_BASE_URL=https://www.rosettastone.com
ROSETTA_LOGIN_URL=https://login.rosettastone.com/login

# --- Configuración de completación ---
# Unidades a completar (separadas por comas, vacío = todas las unidades)
# Ejemplo: ROSETTA_UNITS_TO_COMPLETE=1,2,3,10
ROSETTA_UNITS_TO_COMPLETE=

# Lecciones a completar dentro de cada unidad (separadas por comas, vacío = todas las lecciones)
# Ejemplo: ROSETTA_LESSONS_TO_COMPLETE=1,2,3
ROSETTA_LESSONS_TO_COMPLETE=

# Tipos de paths/hitos a completar (separados por comas, vacío = todos los tipos)
# Tipos disponibles: general, pronunciation, vocabulary, grammar, writing, reading, speaking, listening, review, production_milestone
# Ejemplo para solo completar hitos: ROSETTA_PATH_TYPES_TO_COMPLETE=production_milestone
# Ejemplo para completar varios tipos: ROSETTA_PATH_TYPES_TO_COMPLETE=pronunciation,vocabulary,grammar,production_milestone
ROSETTA_PATH_TYPES_TO_COMPLETE=

# --- Configuración de puntaje y tiempo ---
# Porcentaje objetivo de respuestas correctas (0-100)
ROSETTA_TARGET_SCORE_PERCENT=100

# Offset máximo de tiempo de inicio en milisegundos — ahora se usa para un pequeño
# jitter realista alrededor del momento de la ejecución real (no días en el pasado)
# Por defecto ~5 minutos (300 000 ms). Incrementar si quieres mayor dispersión.
ROSETTA_MAX_START_TIME_OFFSET_MS=300000

# Retraso mínimo entre paths en milisegundos (modo secuencial)
ROSETTA_INTER_PATH_DELAY_MIN_MS=1500

# Retraso máximo entre paths en milisegundos (modo secuencial)
ROSETTA_INTER_PATH_DELAY_MAX_MS=5000

# (Legado) Retraso entre paths — ignorado si se definen MIN/MAX. Mantener por compatibilidad.
ROSETTA_INTER_PATH_DELAY_MS=500

# ==========================================
# MODO DE VELOCIDAD (rápido por defecto)
# ==========================================

# false (por defecto) = RÁPIDO: completa TODOS los paths elegibles en una sola
#   ejecución, sin topes de lote/diarios y sin esperas entre paths.
# true = HUMANO GRADUAL: usa los topes de lote/diarios y las esperas de abajo.
ROSETTA_HUMAN_MODE=false

# ==========================================
# MODO HUMANO GRADUAL (solo si ROSETTA_HUMAN_MODE=true)
# ==========================================

# Número mínimo de paths a completar en una sola ejecución
ROSETTA_BATCH_MIN_PATHS=6

# Número máximo de paths a completar en una sola ejecución
ROSETTA_BATCH_MAX_PATHS=14

# Tope diario de paths: si ya se completaron este número hoy, la ejecución termina sin hacer nada
# (evita que varias ejecuciones programadas en el mismo día lo completen todo de golpe)
ROSETTA_MAX_PATHS_PER_DAY=18

# Directorio donde se guardan los archivos de estado por cuenta (ruta relativa al .exe / directorio de trabajo)
# Por defecto: state/  (se crea automáticamente si no existe)
ROSETTA_STATE_DIR=state


# ==========================================
# BROWSER CONFIGURATION
# ==========================================

# Navegador a usar: "chrome" o "msedge" (instalado en el sistema) — recomendado
# para el .exe, así no hace falta `playwright install`. Vacío = Chromium de Playwright.
BROWSER_CHANNEL=chrome

# Ejecutar navegador en modo headless (sin interfaz gráfica)
BROWSER_HEADLESS=false

# Velocidad de movimiento del navegador en milisegundos (0 = velocidad normal)
BROWSER_SLOW_MO=0

# User agent del navegador
BROWSER_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36

# Idioma/locale del navegador
BROWSER_LOCALE=en-US

# Dimensiones de la ventana del navegador
BROWSER_VIEWPORT_WIDTH=1280
BROWSER_VIEWPORT_HEIGHT=720
